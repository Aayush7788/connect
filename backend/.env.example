APP_ENV=development
APP_NAME=Connect Textile Marketplace API
API_BASE_URL=http://127.0.0.1:8000
API_V1_PREFIX=/v1
LOG_LEVEL=info
ENABLE_DEBUG_ERRORS=false

DATABASE_URL=postgresql+psycopg://postgres:replace-with-dev-db-password@db.your-project.supabase.co:5432/postgres?sslmode=require

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-dev-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-dev-service-role-key
SUPABASE_JWT_SECRET=replace-with-dev-jwt-secret

SUPABASE_PUBLIC_MEDIA_BUCKET=public-media
SUPABASE_PRIVATE_VERIFICATION_BUCKET=verification-documents

FCM_SERVICE_ACCOUNT_JSON_PATH=./secrets/firebase-service-account.json

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CONTACT_REVEAL_MODE=free_unlimited
MAX_UPLOAD_MB=10
